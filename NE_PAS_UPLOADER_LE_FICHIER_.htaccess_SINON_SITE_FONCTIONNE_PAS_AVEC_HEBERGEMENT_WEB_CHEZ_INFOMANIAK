# .htaccess pour ZamanIA
# Fichier de configuration Apache pour améliorer les performances,
# la sécurité et le SEO du site

# ============================================
# COMPRESSION GZIP
# ============================================
# Compresse les fichiers pour réduire la bande passante
# et améliorer les temps de chargement

<IfModule mod_deflate.c>
    # Compresser les fichiers HTML, CSS, JavaScript, XML, JSON
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================
# MISE EN CACHE DU NAVIGATEUR
# ============================================
# Indique au navigateur combien de temps garder
# les fichiers en cache pour éviter de les retélécharger

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images : 1 an
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS et JavaScript : 1 mois
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Polices : 1 an
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    
    # HTML : 1 heure (pour avoir les mises à jour rapidement)
    ExpiresByType text/html "access plus 1 hour"
    
    # Données : pas de cache
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# En-têtes de cache alternatifs si mod_expires n'est pas disponible
<IfModule mod_headers.c>
    # Images
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # CSS et JS
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
    
    # HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=3600, public"
    </FilesMatch>
</IfModule>

# ============================================
# REDIRECTIONS HTTPS
# ============================================
# Force l'utilisation de HTTPS pour la sécurité
# (Important pour le SEO : Google favorise HTTPS)

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Rediriger HTTP vers HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Rediriger www vers non-www (ou inverse selon préférence)
    # Décommentez celle que vous voulez :
    
    # Option 1 : www vers non-www
    RewriteCond %{HTTP_HOST} ^www\.zamania\.fr [NC]
    RewriteRule ^(.*)$ https://zamania.fr/$1 [L,R=301]
    
    # Option 2 : non-www vers www (commentée par défaut)
    # RewriteCond %{HTTP_HOST} ^zamania\.fr [NC]
    # RewriteRule ^(.*)$ https://www.zamania.fr/$1 [L,R=301]
</IfModule>

# ============================================
# EN-TÊTES DE SÉCURITÉ
# ============================================
# Améliorent la sécurité et sont appréciés par Google

<IfModule mod_headers.c>
    # Protection contre le clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Protection XSS
    Header always set X-XSS-Protection "1; mode=block"
    
    # Empêcher le sniffing MIME
    Header always set X-Content-Type-Options "nosniff"
    
    # Référent-Policy (ne pas envoyer le référent vers d'autres sites)
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions-Policy (anciennement Feature-Policy)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Content Security Policy (CSP) - À personnaliser selon vos besoins
    # Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'"
</IfModule>

# ============================================
# PAGES D'ERREUR PERSONNALISÉES
# ============================================
# Améliore l'expérience utilisateur et le SEO

ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# ============================================
# OPTIMISATION DES PERFORMANCES
# ============================================

# Désactiver les ETags (pour améliorer la mise en cache)
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# Limiter la taille des uploads (optionnel)
php_value upload_max_filesize 10M
php_value post_max_size 10M

# ============================================
# PROTECTION DES FICHIERS SENSIBLES
# ============================================

# Empêcher l'accès aux fichiers de configuration
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protéger les fichiers sensibles
<FilesMatch "(\.htaccess|\.htpasswd|\.env|\.git)">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================
# URL REWRITING POUR SEO
# ============================================
# Créer des URLs propres et lisibles

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Supprimer le .html des URLs
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.*)$ $1.html [L]
    
    # Rediriger les anciennes URLs si nécessaire
    # Exemple : Redirect 301 /old-page.html /new-page
</IfModule>

# ============================================
# DÉSACTIVER LE LISTING DES RÉPERTOIRES
# ============================================
# Pour la sécurité et le SEO

Options -Indexes

# ============================================
# CHARSET PAR DÉFAUT
# ============================================
# Important pour l'affichage correct des caractères

AddDefaultCharset UTF-8

# ============================================
# TYPES MIME
# ============================================
# Assurer que les types de fichiers sont correctement reconnus

<IfModule mod_mime.c>
    # JavaScript
    AddType application/javascript js
    
    # JSON
    AddType application/json json
    
    # Polices
    AddType font/woff woff
    AddType font/woff2 woff2
    
    # Images
    AddType image/webp webp
    AddType image/svg+xml svg svgz
</IfModule>

# ============================================
# NOTES D'UTILISATION
# ============================================
#
# 1. Ce fichier doit être placé à la racine du site
# 2. Nécessite un serveur Apache avec mod_rewrite activé
# 3. Testez les modifications progressivement
# 4. Certaines directives peuvent nécessiter des permissions serveur
# 5. En cas d'erreur 500, commentez les sections problématiques
